---
import Layout from "../layouts/Layout.astro";
import PageTitle from "@/components/PageTitle.astro";
---

<Layout title="Projects" theme="purple" blobType="circle-pentagon">
  <PageTitle text="My Projects" />
  <p class="mt-8 text-2xl">This is the projects page with a purple theme!</p>

  <a 
    href="/about" 
    class="mt-16 rounded-full bg-purple-500 px-8 py-3 text-xl font-bold text-white transition-transform hover:scale-105"
  >
    Go Back to About
  </a>
</Layout>
