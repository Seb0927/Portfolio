---
import Layout from "../layouts/Layout.astro";

// This will apply the purple classes automatically via the Layout
const pageTheme = "purple";
---

<Layout title="Projects" theme={pageTheme} blobType="circle-pentagon">
  <div class="flex h-full w-full flex-col items-center justify-center">
    <h1 class="text-6xl font-bold">My Projects</h1>
    <p class="mt-8 text-2xl">This is the projects page with a purple theme!</p>

    <!-- Quick button to go back to About page and test the transition back -->
    <a 
      href="/about" 
      class="mt-16 rounded-full bg-purple-500 px-8 py-3 text-xl font-bold text-white transition-transform hover:scale-105"
    >
      Go Back to About
    </a>
  </div>
</Layout>
