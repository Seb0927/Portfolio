---
import Layout from "../layouts/Layout.astro";
import PageTitle from "@/components/PageTitle.astro";
import ExperienceCard from "@/components/ExperienceCard.astro";
import line from "@/assets/vectors/line.svg?raw";
import curve from "@/assets/vectors/curve.svg?raw";
---

<Layout title="Experience" theme="amber" blobType="diamond-medium-alternates">
  <PageTitle text="Experience" />

  <!-- Spacer element to force <main> to stretch -->
  <div class="md:h-458 2xl:h-294 w-full"></div>

  <!-- Left side -->
  <div class="absolute top-0 xl:left-1/5 md:left-1/12 w-0">
    <!-- Top vertical line -->
    <div
      class="w-px"
      aria-hidden="true"
      style={`color: var(--theme-darkest)`}
      set:html={line}
    />
    <!-- Bottom vertical line -->
    <div
      class="w-px"
      aria-hidden="true"
      style={`color: var(--theme-darkest)`}
      set:html={line}
    />

    <!-- Row 1: left-to-right -->
    <div class="relative flex xl:w-[60vw] md:w-[83.3vw] flex-row">
      <!-- Curve -->
      <div
        class="self-start"
        aria-hidden="true"
        style={`color: var(--theme-darkest)`}
        set:html={curve}
      />
      <!-- Content containers -->
      <ol
        class="flex w-[calc(100%-160px)] -translate-y-[calc(50%-79px)] list-none flex-row items-center gap-x-16 p-0"
      >
        <div
          class="absolute top-1/2 left-0 -z-10 w-full border-t border-(--theme-darkest)"
          aria-hidden="true"
        >
        </div>
        <ExperienceCard
          role="Panamerican Games Volunteer"
          description="I facilitated effective communication between English-speaking individuals and the teams responsible for organizing the games."
          year="2023"
          contentPosition="top"
          pinDirection="up"
        />
        <ExperienceCard
          role="Academic Assistant"
          description="I provided socio-educational support to first-semester students to offer academic assistance in programming courses."
          year="2024"
          contentPosition="bottom"
          pinDirection="down"
        />
        <!-- Hidden below 2xl: shown when 3 cards per row -->
        <ExperienceCard
          role="Technical Support Monitor"
          description="I provided technical support for audiovisual and computer equipment in classrooms and labs at Universidad del Valle"
          year="2024"
          contentPosition="top"
          pinDirection="up"
          displayClass="hidden 2xl:flex"
        />
      </ol>
      <!-- S-curve connector -->
      <div class="flex translate-y-[79px] flex-col">
        <!-- Curve -->
        <div
          class="rotate-180 self-start"
          aria-hidden="true"
          style={`color: var(--theme-darkest)`}
          set:html={curve}
        />
        <!-- Vertical line -->
        <div
          class="w-px self-end"
          aria-hidden="true"
          style={`color: var(--theme-darkest)`}
          set:html={line}
        />
      </div>
    </div>
  </div>

  <!-- Right side (2xl+: 3 cards per row) -->
  <div
    class="absolute top-[calc(492px+404px)] left-4/5 flex hidden flex-col 2xl:flex"
  >
    <!-- Initial -->
    <div class="absolute right-0 flex flex-col">
      <!-- Vertical line -->
      <div
        class="w-px self-end"
        aria-hidden="true"
        style={`color: var(--theme-darkest)`}
        set:html={line}
      />
      <!-- Row 2: right-to-left -->
      <!-- h-0 property is there in order to 
       adjust the space occupied by content containers
       since translate does not move the original layout 
       space behind -->
      <div class="relative flex h-0 w-[60vw] flex-row-reverse">
        <!-- Curve -->
        <div
          class="rotate-270 self-start"
          aria-hidden="true"
          style={`color: var(--theme-darkest)`}
          set:html={curve}
        />

        <!-- Content containers -->
        <ol
          class="flex w-[calc(100%-160px)] -translate-y-[calc(50%-79px)] list-none flex-row-reverse items-center gap-x-16 p-0"
        >
          <div
            class="absolute top-1/2 left-0 -z-10 w-full border-t border-(--theme-darkest)"
            aria-hidden="true"
          >
          </div>
          <ExperienceCard
            role="Software Developer Intern"
            description="I built an interactive web application for dynamic visualization of key indicators, and support ETL processes that gathered data"
            year="2025"
            contentPosition="top"
            pinDirection="up"
          />
          <ExperienceCard
            role="Implementation Consultant"
            description="I led the onboarding lifecycle through timelines, effective customer transitions toward optimal product adoption."
            year="2025"
            yearLabel="Today"
            contentPosition="bottom"
            pinDirection="down"
          />
          <!-- Empty placeholder to maintain 3-column layout spacing -->
          <li
            class="relative flex h-140 flex-1 flex-col items-center"
            aria-hidden="true"
          >
          </li>
        </ol>

        <!-- Left side -->
        <div class="absolute top-0 left-0 flex translate-y-[79px] flex-col">
          <!-- Curve -->
          <div
            class="rotate-90 self-start"
            aria-hidden="true"
            style={`color: var(--theme-darkest)`}
            set:html={curve}
          />
          <!-- Vertical line -->
          <div
            aria-hidden="true"
            style={`color: var(--theme-darkest)`}
            set:html={line}
          />
        </div>
      </div>
    </div>
  </div>

  <!-- Right side (below 2xl: 2 cards per row) -->
  <div
    class="absolute xl:left-4/5 md:left-11/12 flex flex-col 2xl:hidden"
    style="top: calc(492px + 404px)"
  >
    <!-- Initial -->
    <div class="absolute right-0 flex flex-col">
      <!-- Vertical line -->
      <div
        class="w-px self-end"
        aria-hidden="true"
        style={`color: var(--theme-darkest)`}
        set:html={line}
      />
      <!-- Row 2: right-to-left (2 cards) -->
      <div class="relative flex h-0 xl:w-[60vw] md:w-[83.3vw] flex-row-reverse">
        <!-- Curve -->
        <div
          class="rotate-270 self-start"
          aria-hidden="true"
          style={`color: var(--theme-darkest)`}
          set:html={curve}
        />

        <!-- Content containers -->
        <ol
          class="flex w-[calc(100%-160px)] -translate-y-[calc(50%-79px)] list-none flex-row-reverse items-center gap-x-16 p-0"
        >
          <div
            class="absolute top-1/2 left-0 -z-10 w-full border-t border-(--theme-darkest)"
            aria-hidden="true"
          >
          </div>
          <ExperienceCard
            role="Technical Support Monitor"
            description="I provided technical support for audiovisual and computer equipment in classrooms and labs at Universidad del Valle"
            year="2024"
            contentPosition="top"
            pinDirection="up"
          />
          <ExperienceCard
            role="Software Developer Intern"
            description="I built an interactive web application for dynamic visualization of key indicators, and support ETL processes that gathered data"
            year="2025"
            contentPosition="bottom"
            pinDirection="down"
          />
        </ol>

        <!-- Left side -->
        <div class="absolute top-0 left-0 flex translate-y-[79px] flex-col">
          <!-- Curve -->
          <div
            class="rotate-90 self-start"
            aria-hidden="true"
            style={`color: var(--theme-darkest)`}
            set:html={curve}
          />
          <!-- Vertical line -->
          <div
            aria-hidden="true"
            style={`color: var(--theme-darkest)`}
            set:html={line}
          />
        </div>
      </div>
    </div>
  </div>

  <!-- Row 3 (below 2xl only: left-to-right) -->
  <div
    class="absolute xl:left-1/5 md:left-1/12 w-0 2xl:hidden"
    style="top: calc(492px + 404px + 492px + 159px)"
  >
    <!-- Vertical line -->
    <div
      class="w-px"
      aria-hidden="true"
      style={`color: var(--theme-darkest)`}
      set:html={line}
    />

    <div class="relative flex h-0 xl:w-[60vw] md:w-[83.3vw] flex-row">
      <!-- Curve -->
      <div
        class="self-start"
        aria-hidden="true"
        style={`color: var(--theme-darkest)`}
        set:html={curve}
      />
      <!-- Content containers -->
      <ol
        class="flex w-[calc(100%-160px)] -translate-y-[calc(50%-79px)] list-none flex-row items-center gap-x-16 p-0"
      >
        <div
          class="absolute top-1/2 left-0 -z-10 w-full flex-1 border-t border-(--theme-darkest)"
          aria-hidden="true"
        >
        </div>
      </li>
        <ExperienceCard
          role="Implementation Consultant"
          description="I led the onboarding lifecycle through timelines, effective customer transitions toward optimal product adoption."
          year="2025"
          yearLabel="Today"
          contentPosition="top"
          pinDirection="up"
        />
        <!-- Empty placeholder to maintain 3-column layout spacing -->
      <li
        class="relative flex h-140 flex-1 flex-col items-center"
        aria-hidden="true"
      >
      </ol>
      <!-- Finishing curve + line -->
      <div class="flex translate-y-[79px] flex-col">
        <div
          class="rotate-180 self-start"
          aria-hidden="true"
          style={`color: var(--theme-darkest)`}
          set:html={curve}
        />
        <div
          class="w-px self-end"
          aria-hidden="true"
          style={`color: var(--theme-darkest)`}
          set:html={line}
        />
      </div>
    </div>
  </div>
</Layout>
