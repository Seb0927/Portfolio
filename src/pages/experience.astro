---
import Layout from "../layouts/Layout.astro";
import PageTitle from "@/components/PageTitle.astro";
import line from "@/assets/vectors/line.svg?raw";
import curve from "@/assets/vectors/curve.svg?raw";
import pin from "@/assets/vectors/pin.svg?raw";
---

<Layout title="Experience" theme="amber" blobType="diamond-medium-alternates">
  <PageTitle text="Experience" />

  <!-- Spacer element to force <main> to stretch -->
  <div class="h-294 w-full"></div>

  <!-- Left side -->
  <div class="absolute top-0 left-1/5 w-0">
    <!-- Vertical line -->
    <div class="w-px" style={`color: var(--theme-darkest)`} set:html={line} />
    <!-- Vertical line -->
    <div class="w-px" style={`color: var(--theme-darkest)`} set:html={line} />

    <!-- First Content -->
    <div class="relative flex w-[60vw] flex-row">
      <!-- Curve -->
      <div
        class="self-start"
        style={`color: var(--theme-darkest)`}
        set:html={curve}
      />
      <!-- Content containers -->
      <div
        class="flex w-[calc(100%-160px)] -translate-y-[calc(50%-79px)] flex-row items-center gap-x-16"
      >
        <div
          class="absolute top-1/2 left-0 -z-10 w-full border-t border-(--theme-darkest)"
        >
        </div>
        <div class="relative flex h-140 flex-1 flex-col items-center">
          <div class="mb-16 flex flex-1 flex-col gap-4">
            <h2 class="max-h-16 overflow-auto text-center text-2xl font-bold">
              Panamerican Games Volunteer
            </h2>
            <p class="flex h-30 items-center overflow-auto">
              I facilitated effective communication between English-speaking
              individuals and the teams responsible for organizing the games.
            </p>
            <span class="text-center text-xl font-bold">2023</span>
          </div>
          <div
            class="absolute top-[calc(50%-8px)] flex -translate-y-1/2 items-center justify-center"
          >
            <div style="color: var(--theme-darkest)" set:html={pin} />
          </div>
          <div class="flex-1"></div>
        </div>

        <div class="relative flex h-140 flex-1 flex-col items-center">
          <div class="flex-1"></div>
          <div class="mt-20 flex flex-1 flex-col gap-4">
            <h2 class="max-h-16 overflow-auto text-center text-2xl font-bold">
              Academic Assistant
            </h2>
            <p class="flex h-30 items-center overflow-auto">
              I provided socio-educational support to first-semester students to
              offer academic assistance in programming courses.
            </p>
            <span class="text-center text-xl font-bold">2024</span>
          </div>
          <div
            class="absolute top-[calc(50%+10px)] flex -translate-y-1/2 rotate-180 items-center justify-center"
          >
            <div style="color: var(--theme-darkest)" set:html={pin} />
          </div>
        </div>

        <div class="relative flex h-140 flex-1 flex-col items-center">
          <div class="mb-16 flex flex-1 flex-col gap-4">
            <h2 class="max-h-16 overflow-auto text-center text-2xl font-bold">
              Technical Support Monitor
            </h2>
            <p class="flex h-30 items-center overflow-auto">
              I provided technical support for audiovisual and computer
              equipment in classrooms and labs at Universidad del Valle
            </p>
            <span class="text-center text-xl font-bold">2024</span>
          </div>
          <div
            class="absolute top-[calc(50%-8px)] flex -translate-y-1/2 items-center justify-center"
          >
            <div style="color: var(--theme-darkest)" set:html={pin} />
          </div>
          <div class="flex-1"></div>
        </div>
      </div>
      <div class="flex translate-y-[79px] flex-col">
        <!-- Curve -->
        <div
          class="rotate-180 self-start"
          style={`color: var(--theme-darkest)`}
          set:html={curve}
        />
        <!-- Vertical line -->
        <div
          class="w-px self-end"
          style={`color: var(--theme-darkest)`}
          set:html={line}
        />
      </div>
    </div>
  </div>

  <!-- Right side -->
  <div class="absolute top-[calc(492px+404px)] left-4/5 flex flex-col">
    <!-- Initial -->
    <div class="absolute right-0 flex flex-col">
      <!-- Vertical line -->
      <div
        class="w-px self-end"
        style={`color: var(--theme-darkest)`}
        set:html={line}
      />
      <!-- Second Content -->
      <!-- h-0 property is there in order to 
       adjust the space occupied by content containers
       since translate does not move the original layout 
       space behind -->
      <div class="relative flex h-0 w-[60vw] flex-row-reverse">
        <!-- Curve -->
        <div
          class="rotate-270 self-start"
          style={`color: var(--theme-darkest)`}
          set:html={curve}
        />

        <!-- Content containers -->
        <div
          class="flex w-[calc(100%-160px)] -translate-y-[calc(50%-79px)] flex-row-reverse items-center gap-x-16"
        >
          <div
            class="absolute top-1/2 left-0 -z-10 w-full border-t border-(--theme-darkest)"
          >
          </div>
          <div class="relative flex h-140 flex-1 flex-col items-center">
            <div class="mb-16 flex flex-1 flex-col gap-4">
              <h2 class="max-h-16 overflow-auto text-center text-2xl font-bold">
                Software Developer Intern
              </h2>
              <p class="flex h-30 items-center overflow-auto">
                I built an interactive web application for dynamic visualization
                of key indicators, and support ETL processes that gathered data
              </p>
              <span class="text-center text-xl font-bold">2025</span>
            </div>
            <div
              class="absolute top-[calc(50%-8px)] flex -translate-y-1/2 items-center justify-center"
            >
              <div style="color: var(--theme-darkest)" set:html={pin} />
            </div>
            <div class="flex-1"></div>
          </div>

          <div class="relative flex h-140 flex-1 flex-col items-center">
            <div class="flex-1"></div>
            <div class="mt-16 flex flex-1 flex-col gap-4">
              <h2 class="max-h-16 overflow-auto text-center text-2xl font-bold">
                Implementation Consultant
              </h2>
              <p class="flex h-30 items-center overflow-auto">
                I led the onboarding lifecycle through timelines, effective
                customer transitions toward optimal product adoption.
              </p>
              <span class="text-center text-xl font-bold">Today</span>
            </div>
            <div
              class="absolute top-[calc(50%+10px)] flex -translate-y-1/2 rotate-180 items-center justify-center"
            >
              <div style="color: var(--theme-darkest)" set:html={pin} />
            </div>
          </div>

          <div class="relative flex h-140 flex-1 flex-col items-center"></div>
        </div>

        <!-- Left side -->
        <div class="absolute top-0 left-0 flex translate-y-[79px] flex-col">
          <!-- Curve -->
          <div
            class="rotate-90 self-start"
            style={`color: var(--theme-darkest)`}
            set:html={curve}
          />
          <!-- Vertical line -->
          <div
            style={`color: var(--theme-darkest)`}
            set:html={line}
          />
        </div>
      </div>
    </div>
  </div>
</Layout>
