---
import "@/styles/global.css";
import { ClientRouter } from "astro:transitions";
import { Font } from "astro:assets";
import { ChevronLeft, ChevronRight } from "@lucide/astro";
import BackgroundBlobs from "@/components/BackgroundBlobs.astro";
import { navLinks } from "@/constants/navigation";
import type { Theme, BlobType } from "@/types";

interface Props {
  title: string;
  theme: Theme;
  blobType: BlobType;
}

const { title, theme, blobType } = Astro.props;

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Sebastián Idrobo - Software Engineer portfolio showcasing projects, experience, and blog posts."
    />
    <meta property="og:title" content={`${title} | Sebastián's Portfolio`} />
    <meta
      property="og:description"
      content="Sebastián Idrobo - Software Engineer portfolio showcasing projects, experience, and blog posts."
    />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Sebastián's Portfolio</title>
    <Font cssVariable="--font-inter" />
    <ClientRouter />
  </head>

  <body
    class="relative flex min-h-screen min-w-screen flex-col items-center justify-center bg-(--theme-lightest) px-40 py-14 text-black"
    data-theme={theme}
  >
    <BackgroundBlobs type={blobType} />

    <ChevronLeft
      size={92}
      class="fixed top-1/2 left-16 z-50 -translate-y-1/2 text-(--theme-darkest)"
      aria-hidden="true"
    />

    <div class="z-10 mt-4 w-full max-w-xl">
      <nav aria-label="Main navigation">
        <ul class="flex flex-row justify-center">
          {
            navLinks.map((link) => (
              <li class="flex-1 p-2 text-center text-lg font-medium">
                <a href={link.path} class="block w-full">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="flex h-1.5 flex-row">
        {
          navLinks.map((link) => {
            const isActive = currentPath === link.path;
            return (
              <div class="flex-1 bg-(--theme-default) transition-colors duration-700">
                {isActive && (
                  <div
                    transition:name="nav-indicator"
                    class="bg---theme-darkest) h-full w-full"
                  />
                )}
              </div>
            );
          })
        }
      </div>
    </div>

    <main class="flex h-full max-w-7xl flex-1 flex-col items-center px-8 py-10">
      <slot />
    </main>

    <ChevronRight
      size={92}
      class="fixed top-1/2 right-16 z-50 -translate-y-1/2 text-(--theme-darkest)"
      aria-hidden="true"
    />
  </body>
</html>
