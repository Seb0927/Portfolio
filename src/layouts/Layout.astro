---
import "@/styles/global.css";
import { ClientRouter } from "astro:transitions";
import { Font } from "astro:assets";
import BackgroundBlobs from "@/components/BackgroundBlobs.astro";
import Navbar from "@/components/Navbar.astro";
import type { Theme, BlobType } from "@/types";

interface Props {
  title: string;
  theme: Theme;
  blobType: BlobType;
}

const { title, theme, blobType } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Sebastián Idrobo - Software Engineer portfolio showcasing projects, experience, and blog posts."
    />
    <meta property="og:title" content={`${title} | Sebastián's Portfolio`} />
    <meta
      property="og:description"
      content="Sebastián Idrobo - Software Engineer portfolio showcasing projects, experience, and blog posts."
    />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Sebastián's Portfolio</title>
    <Font cssVariable="--font-inter" />
    <ClientRouter />
  </head>

  <body
    class="relative flex min-h-screen min-w-screen flex-col items-center justify-center bg-(--theme-lightest) px-6 pt-10 pb-12 text-black md:px-20 lg:px-32 xl:px-40"
    data-theme={theme}
  >
    <BackgroundBlobs type={blobType} />

    <Navbar />

    <main class="flex h-full w-full max-w-7xl flex-1 flex-col items-center px-8 py-10">
      <slot />
    </main>
  </body>
</html>
