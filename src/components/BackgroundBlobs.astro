---
import type { BlobType } from "@/types";
import roundedStar from "@/assets/vectors/rounded-star.svg?raw";
import circlePentagon from "@/assets/vectors/circle-pentagon.svg?raw";
import diamondMediumAlternates from "@/assets/vectors/diamond-medium-alternates.svg?raw";

interface Props {
  type: BlobType;
}

const { type } = Astro.props;

const blobSvg: Record<BlobType, string> = {
  "rounded-star": roundedStar,
  "circle-pentagon": circlePentagon,
  "diamond-medium-alternates": diamondMediumAlternates,
};

const blobs = [
  {
    position: "top-0 right-0 translate-x-1/2 -translate-y-1/2",
    spinClass: "animate-blob-spin-20",
  },
  {
    position: "top-1/2 left-0 -translate-x-1/2 -translate-y-1/2",
    spinClass: "animate-blob-spin-25-reverse",
  },
  {
    position: "bottom-0 right-0 translate-x-1/2 translate-y-1/2",
    spinClass: "animate-blob-spin-22",
  },
];
---

<div
  transition:name="page-blobs"
  aria-hidden="true"
  class="pointer-events-none absolute inset-0 z-0 overflow-hidden"
>
  <!--
    Each blob is split into two nested elements to avoid transform conflicts.
    Having spin and click-scale on the same element causes a visible skip,
    since the scale overrides the ongoing rotation. The outer div handles
    position + click scale, the inner div handles the continuous spin.
  -->
  {
    blobs.map((blob) => (
      <div
        data-blob
        class={`blob-wrapper pointer-events-auto absolute ${blob.position} h-64 w-64 cursor-pointer`}
      >
        <div
          class={`h-full w-full ${blob.spinClass} blob-shape`}
          style={`color: var(--theme-default)`}
          set:html={blobSvg[type]}
        />
      </div>
    ))
  }
</div>

<style>
  .blob-shape :global(svg) {
    width: 100%;
    height: 100%;
  }

  @keyframes blob-click {
    0% {
      scale: 1;
    }
    50% {
      scale: 1.15;
    }
    100% {
      scale: 1;
    }
  }

  .blob-wrapper.blob-clicked {
    animation: blob-click 300ms ease;
  }
</style>

<script>
  import popSound from "@/assets/audio/pop.webm?url";

  const pop = new Audio(popSound);

  document.addEventListener("pointerdown", (e) => {
    const wrapper = (e.target as HTMLElement).closest(
      "[data-blob]",
    ) as HTMLElement | null;
    if (!wrapper) return;

    pop.currentTime = 0;
    pop.play();

    wrapper.classList.remove("blob-clicked");
    requestAnimationFrame(() => {
      wrapper.classList.add("blob-clicked");
    });
  });

  document.addEventListener("animationend", (e) => {
    const target = e.target as HTMLElement;
    if (target.dataset.blob !== undefined) {
      target.classList.remove("blob-clicked");
    }
  });
</script>
