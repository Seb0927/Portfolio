---
import type { PathType } from "@/types";
import line from "@/assets/vectors/line.svg?raw";
import curve from "@/assets/vectors/curve.svg?raw";

interface Props {
  type: PathType;
  orderSm: number;
  orderMd: number;
  orderXl: number;
  hiddenMd?: boolean;
  hiddenXl?: boolean;
}

const {
  type,
  orderSm,
  orderMd,
  orderXl,
  hiddenMd = false,
  hiddenXl = false,
} = Astro.props;

const pathConfigs: Record<
  PathType,
  {
    lineFirst: boolean;
    lineAlign: "left" | "right";
    curveRotation: number;
    hasTranslate: boolean;
  }
> = {
  "top-left": {
    lineFirst: true,
    lineAlign: "left",
    curveRotation: 0,
    hasTranslate: false,
  },
  "bottom-right": {
    lineFirst: false,
    lineAlign: "right",
    curveRotation: 180,
    hasTranslate: true,
  },
  "bottom-left": {
    lineFirst: true,
    lineAlign: "right",
    curveRotation: 270,
    hasTranslate: false,
  },
  "top-right": {
    lineFirst: false,
    lineAlign: "left",
    curveRotation: 90,
    hasTranslate: true,
  },
};

const config = pathConfigs[type];
---

<div
  class:list={[
    "experience-path h-min max-w-20",
    { "translate-y-[calc(100%-1px)]": config.hasTranslate },
    { "md:hidden": hiddenMd },
    { "2xl:hidden": hiddenXl },
  ]}
  style={`--order-sm: ${orderSm}; --order-md: ${orderMd}; --order-xl: ${orderXl};`}
  aria-hidden="true"
>
  {
    config.lineFirst ? (
      <>
        <div
          class:list={[
            "w-px",
            config.lineAlign === "left" ? "mr-auto" : "ml-auto",
          ]}
          style={`color: var(--theme-darkest);`}
          set:html={line}
        />
        <div
          class="size-20"
          style={`transform: rotate(${config.curveRotation}deg); color: var(--theme-darkest);`}
          set:html={curve}
        />
      </>
    ) : (
      <>
        <div
          class="size-20"
          style={`transform: rotate(${config.curveRotation}deg); color: var(--theme-darkest);`}
          set:html={curve}
        />
        <div
          class:list={[
            "w-px",
            config.lineAlign === "left" ? "mr-auto" : "ml-auto",
          ]}
          style={`color: var(--theme-darkest);`}
          set:html={line}
        />
      </>
    )
  }
</div>

<style>
  .experience-path {
    order: var(--order-sm);
  }

  @media (min-width: 768px) {
    .experience-path {
      order: var(--order-md);
    }
  }

  @media (min-width: 1536px) {
    .experience-path {
      order: var(--order-xl);
    }
  }
</style>
