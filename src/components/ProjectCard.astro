---
import { Image } from "astro:assets";
import TechIcon from "./TechIcon.astro";

interface Props {
  title: string;
  description: string;
  icons: { svg: string; class?: string }[];
  image: ImageMetadata;
  imageAlt: string;
  imagePosition: "left" | "right";
}

const { title, description, icons, image, imageAlt, imagePosition } =
  Astro.props;
---

<section class="flex w-full flex-col gap-8 md:flex-row md:gap-12 lg:gap-16">
  {
    imagePosition === "left" && (
      <div class="hidden min-h-full items-center justify-center md:flex">
        <div class="flex size-full items-center justify-center rounded-4xl bg-white md:max-h-48 md:w-64 lg:max-h-56 lg:w-80 xl:w-88">
          <Image class="max-h-24 max-w-24" src={image} alt={imageAlt} />
        </div>
      </div>
    )
  }

  <div class="flex flex-1 flex-col gap-4 md:gap-4">
    <h2 class="text-xl font-semibold md:text-3xl">{title}</h2>
    <p>{description}</p>

    <div
      class="my-2 flex min-h-full w-full items-center justify-center md:hidden"
    >
      <div
        class="flex size-full h-48 max-w-xs items-center justify-center rounded-4xl bg-white md:hidden"
      >
        <Image class="max-h-20 max-w-20" src={image} alt={imageAlt} />
      </div>
    </div>

    <div class="flex w-full flex-row gap-8">
      {icons.map((icon) => <TechIcon svg={icon.svg} class={icon.class} />)}
    </div>
  </div>

  {
    imagePosition === "right" && (
      <div class="hidden min-h-full items-center justify-center md:flex">
        <div class="flex size-full items-center justify-center rounded-4xl bg-white md:max-h-48 md:w-64 lg:max-h-56 lg:w-80 xl:w-88">
          <Image class="max-h-24 max-w-24" src={image} alt={imageAlt} />
        </div>
      </div>
    )
  }
</section>
